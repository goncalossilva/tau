#!/usr/bin/env sh
set -eu

# Bootstrap ~/.agents from a remote checkout, then run bin/setup.
#
# Supported pass-through arguments are whatever bin/setup accepts, for example:
#   sh install --pi
#   sh install --claude --prune --yes
#
# Optional environment overrides:
#   AGENTS_INSTALL_REPO=https://github.com/goncalossilva/.agents.git
#   AGENTS_INSTALL_REF=main

REPO_URL="${AGENTS_INSTALL_REPO:-https://github.com/goncalossilva/.agents.git}"
INSTALL_REF="${AGENTS_INSTALL_REF:-main}"
INSTALL_DIR="${HOME}/.agents"
TARBALL_BASE_URL="https://github.com/goncalossilva/.agents/archive/refs"

say() {
  printf '%s\n' "$*"
}

warn() {
  printf 'warn: %s\n' "$*" >&2
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

has_command() {
  command -v "$1" >/dev/null 2>&1
}

is_supported_origin() {
  case "$1" in
    "$REPO_URL" | \
    https://github.com/goncalossilva/.agents.git | \
    https://github.com/goncalossilva/.agents | \
    git@github.com:goncalossilva/.agents.git | \
    git@github.com:goncalossilva/.agents)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

is_dir_empty() {
  [ -d "$1" ] || return 1
  [ -z "$(ls -A "$1" 2>/dev/null)" ]
}

download_file() {
  url="$1"
  output="$2"

  if has_command curl; then
    curl --proto '=https' --tlsv1.2 -fsSL "$url" -o "$output"
    return 0
  fi

  if has_command wget; then
    wget -qO "$output" "$url"
    return 0
  fi

  die "Neither curl nor wget is available"
}

install_or_update_with_git() {
  if [ -e "$INSTALL_DIR" ]; then
    [ -d "$INSTALL_DIR" ] || die "$INSTALL_DIR exists and is not a directory"

    if [ -d "$INSTALL_DIR/.git" ]; then
      origin_url="$(git -C "$INSTALL_DIR" remote get-url origin 2>/dev/null || printf '')"
      [ -n "$origin_url" ] || die "$INSTALL_DIR is a git checkout without an origin remote"
      is_supported_origin "$origin_url" || die "$INSTALL_DIR points at an unexpected origin: $origin_url"

      git -C "$INSTALL_DIR" diff --quiet --ignore-submodules -- || \
        die "$INSTALL_DIR has unstaged changes; update it manually first"
      git -C "$INSTALL_DIR" diff --cached --quiet --ignore-submodules -- || \
        die "$INSTALL_DIR has staged changes; update it manually first"

      say "==> Updating $INSTALL_DIR"
      git -C "$INSTALL_DIR" fetch --tags --prune origin

      if git -C "$INSTALL_DIR" ls-remote --exit-code --heads origin "$INSTALL_REF" >/dev/null 2>&1; then
        git -C "$INSTALL_DIR" fetch --depth 1 origin "$INSTALL_REF"
        git -C "$INSTALL_DIR" checkout -B "$INSTALL_REF" FETCH_HEAD
        return 0
      fi

      if git -C "$INSTALL_DIR" ls-remote --exit-code --tags origin "refs/tags/$INSTALL_REF" >/dev/null 2>&1; then
        git -C "$INSTALL_DIR" checkout --detach "refs/tags/$INSTALL_REF"
        return 0
      fi

      die "Could not find branch or tag '$INSTALL_REF' on origin"
    fi

    is_dir_empty "$INSTALL_DIR" || die "$INSTALL_DIR already exists and is not an empty directory"
  else
    mkdir -p "$(dirname "$INSTALL_DIR")"
  fi

  say "==> Cloning $REPO_URL into $INSTALL_DIR"
  git clone --branch "$INSTALL_REF" --depth 1 "$REPO_URL" "$INSTALL_DIR"
}

install_with_tarball() {
  has_command tar || die "tar is required when git is unavailable"

  if [ -e "$INSTALL_DIR" ]; then
    [ -d "$INSTALL_DIR" ] || die "$INSTALL_DIR exists and is not a directory"
    is_dir_empty "$INSTALL_DIR" || \
      die "$INSTALL_DIR already exists; install git or remove the directory before retrying"
  else
    mkdir -p "$(dirname "$INSTALL_DIR")"
  fi

  temp_dir="$(mktemp -d "${TMPDIR:-/tmp}/agents-install.XXXXXX")"
  cleanup() {
    rm -rf "$temp_dir"
  }
  trap cleanup EXIT INT TERM HUP

  archive_path="$temp_dir/.agents.tar.gz"
  extract_dir="$temp_dir/extracted"
  mkdir -p "$extract_dir"

  branch_url="$TARBALL_BASE_URL/heads/$INSTALL_REF.tar.gz"
  tag_url="$TARBALL_BASE_URL/tags/$INSTALL_REF.tar.gz"

  say "==> Downloading $INSTALL_REF tarball"
  if ! download_file "$branch_url" "$archive_path"; then
    warn "Branch tarball download failed, trying tag tarball"
    download_file "$tag_url" "$archive_path" || die "Could not download branch or tag '$INSTALL_REF'"
  fi

  tar -xzf "$archive_path" -C "$extract_dir"
  set -- "$extract_dir"/*
  [ "$#" -eq 1 ] || die "Unexpected tarball contents"
  [ -d "$1" ] || die "Unexpected tarball contents"

  rm -rf "$INSTALL_DIR"
  mv "$1" "$INSTALL_DIR"
}

run_setup() {
  [ -f "$INSTALL_DIR/bin/setup" ] || die "Missing $INSTALL_DIR/bin/setup after install"
  chmod +x "$INSTALL_DIR/bin/setup" 2>/dev/null || true

  say "==> Running $INSTALL_DIR/bin/setup --prune --yes $*"
  "$INSTALL_DIR/bin/setup" --prune --yes "$@"
}

if [ "${1-}" = "--help" ] && [ "$#" -eq 1 ]; then
  cat <<'EOF'
Bootstrap ~/.agents, then run ~/.agents/bin/setup --prune --yes.

Usage:
  curl --proto '=https' --tlsv1.2 -fsSL \
    https://raw.githubusercontent.com/goncalossilva/.agents/main/bin/install | sh

Pass setup flags after --, for example:
  ... | sh -s -- --pi
  ... | sh -s -- --claude --dry-run

Optional environment overrides:
  AGENTS_INSTALL_REPO  Alternate git clone URL (advanced/testing)
  AGENTS_INSTALL_REF   Branch or tag to install (default: main)
EOF
  exit 0
fi

[ -n "${HOME:-}" ] || die "HOME is not set"

if has_command git; then
  install_or_update_with_git
else
  warn "git not found; falling back to tarball install"
  install_with_tarball
fi

run_setup "$@"
